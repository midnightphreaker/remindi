# Remindi environment configuration
#
# Copy this file to .env before running `docker compose up -d --build`.
# Replace every `change-me-*` value, then run `chmod 600 .env`.
# Never commit your populated .env file.
# Application variables are read once at startup; restart to apply changes.
# Boolean values are strict: use exactly `true` or `false` in lowercase.

# REMINDI_OWNER_ID
# Purpose: Identifies the single owner whose reminders are stored in this database.
# How it works: Remindi scopes every item and derives its MCP actor identity from
# this value and the MCP token. Changing it does not migrate existing ownership.
# Default: none; this setting is required and must not be blank.
# Valid values: any non-empty owner identifier, for example a username or stable ID.
REMINDI_OWNER_ID=change-me-owner

# REMINDI_MCP_TOKEN
# Purpose: Authenticates every request to the Streamable HTTP MCP endpoint.
# How it works: MCP clients send this value as `Authorization: Bearer <token>`;
# Remindi compares it without logging the secret. Rotation requires a restart,
# revokes the old token, changes MCP actor/idempotency scope, and invalidates cursors.
# Default: none; this setting is required and must not be blank.
# Valid values: a non-empty secret without ASCII whitespace; use a long random token.
REMINDI_MCP_TOKEN=change-me-to-a-long-random-token

# REMINDI_DB_PATH
# Purpose: Selects the SQLite database that stores reminders, history, and settings.
# How it works: Remindi creates or opens this file and applies embedded migrations at
# startup. In the supplied container, /data is the persistent named volume.
# Default: /data/remindi.db
# Valid values: an absolute path whose parent directory is private and writable.
REMINDI_DB_PATH=/data/remindi.db

# REMINDI_BACKUP_DIR
# Purpose: Selects the directory for managed database backups and their manifests.
# How it works: Manual, uploaded, and pre-restore backups are reconciled here at
# startup. Keep it on durable storage; do not point it at the live database file.
# Default: /data/backups
# Valid values: an absolute path in a private, writable directory.
REMINDI_BACKUP_DIR=/data/backups

# REMINDI_HTTP_ALLOWED_HOSTS
# Purpose: Restricts accepted MCP Host authorities to prevent host-header abuse.
# How it works: A comma-separated allowlist is matched on /mcp after authority
# normalization. An empty value disables the explicit MCP allowlist, but an MCP
# Host remains required. For a reverse proxy, include the public hostname it sends.
# Default: empty
# Valid values: empty, or comma-separated host[:port] authorities such as
# localhost:8000,mcp.example.com
REMINDI_HTTP_ALLOWED_HOSTS=

# REMINDI_HTTP_ALLOWED_ORIGINS
# Purpose: Controls which supplied browser origins may access the MCP endpoint.
# How it works: A comma-separated list is matched exactly on /mcp. When empty, a
# supplied MCP Origin must have the same authority as Host; native clients may omit
# Origin. WebUI/API mutations always use separate same-origin and CSRF checks.
# Default: empty
# Valid values: empty, or comma-separated exact http/https origins such as
# https://mcp.example.com,http://localhost:8000
REMINDI_HTTP_ALLOWED_ORIGINS=

# REMINDI_LOG_LEVEL
# Purpose: Controls structured application log filtering.
# How it works: The value is parsed as a tracing EnvFilter directive; increasing
# verbosity can aid diagnosis but produces more output.
# Default: info
# Valid values: directives such as error, warn, info, debug, trace, or
# remindi=debug,tower_http=info
REMINDI_LOG_LEVEL=info

# REMINDI_LOG_CONTENT
# Purpose: Records the operator's policy choice for reminder-content logging.
# How it works: Version 0.1 parses and displays this flag but does not consume it;
# logs remain metadata-only for both values. Keep false for forward-safe privacy.
# Default: false
# Valid values: true or false
REMINDI_LOG_CONTENT=false

# REMINDI_WEBUI_ENABLE
# Purpose: Enables the WebUI and its JSON administration API.
# How it works: false removes the UI and /api/v1 routes while leaving MCP and health
# endpoints available.
# Default: true
# Valid values: true or false
REMINDI_WEBUI_ENABLE=true

# REMINDI_WEBUI_AUTH
# Purpose: Requires a username/password login before using the WebUI.
# How it works: true enables in-memory sessions and requires the username and
# password below. false opens the UI, but same-origin/CSRF protections still apply
# and guarded restore is unavailable without configured reauthentication credentials.
# Default: true
# Valid values: true or false
REMINDI_WEBUI_AUTH=true

# REMINDI_WEBUI_USERNAME
# Purpose: Sets the WebUI login username.
# How it works: It is required when the WebUI and WebUI authentication are both
# enabled. It may also provide reauthentication while auth is disabled.
# Default: none
# Valid values: any non-empty username when required; replace the placeholder.
REMINDI_WEBUI_USERNAME=change-me-admin

# REMINDI_WEBUI_PASSWORD
# Purpose: Sets the WebUI login and guarded-action reauthentication password.
# How it works: It is required when the WebUI and WebUI authentication are both
# enabled. Changing it takes effect after restart and invalidates practical access
# through the old credentials.
# Default: none
# Valid values: any non-empty secret when required; use a long unique password.
REMINDI_WEBUI_PASSWORD=change-me-to-a-long-random-password

# REMINDI_WEBUI_SESSION_TTL_SECONDS
# Purpose: Sets how long an authenticated WebUI session remains valid.
# How it works: Sessions live only in process memory and expire after this many
# seconds; every restart invalidates all sessions regardless of this value.
# Default: 43200 (12 hours)
# Valid values: a positive integer greater than zero.
REMINDI_WEBUI_SESSION_TTL_SECONDS=43200

# REMINDI_WEBUI_COOKIE_SECURE
# Purpose: Controls the Secure flag on the WebUI session cookie.
# How it works: true restricts the cookie to HTTPS and should be used behind an
# HTTPS reverse proxy. Leave false only for direct local HTTP access.
# Default: false
# Valid values: true or false
REMINDI_WEBUI_COOKIE_SECURE=false

# REMINDI_WEBUI_TITLE
# Purpose: Customizes the product title shown by the embedded WebUI.
# How it works: The title is safely escaped before it is inserted into the page.
# Default: Remindi
# Valid values: Unicode display text. Compose treats blank as the default; a direct
# native process can receive an explicitly empty value and render a blank title.
REMINDI_WEBUI_TITLE=Remindi

# REMINDI_WEBUI_CUSTOM_CSS_FILE
# Purpose: Adds an operator-supplied CSS override to the embedded WebUI.
# How it works: Remindi reads this regular, non-world-writable UTF-8 file at startup
# and serves it as an immutable asset. In a container, mount the file and use its
# absolute container path.
# Default: empty (no custom CSS)
# Valid values: empty, or an absolute path to a readable CSS file up to 256 KiB.
REMINDI_WEBUI_CUSTOM_CSS_FILE=

# REMINDI_WEBUI_LOGO_FILE
# Purpose: Replaces the default WebUI logo.
# How it works: Remindi validates a regular, non-world-writable asset at startup.
# In a container, mount the file and use its absolute container path.
# Default: empty (built-in logo)
# Valid values: empty, or an absolute SVG/PNG/JPEG/GIF/WebP up to 2 MiB.
REMINDI_WEBUI_LOGO_FILE=

# REMINDI_WEBUI_FAVICON_FILE
# Purpose: Replaces the default browser favicon.
# How it works: Remindi validates a regular, non-world-writable asset at startup.
# In a container, mount the file and use its absolute container path.
# Default: empty (built-in favicon)
# Valid values: empty, or an absolute SVG/PNG/JPEG/GIF/WebP/ICO up to 512 KiB.
REMINDI_WEBUI_FAVICON_FILE=

# REMINDI_WEBUI_HOST
# Purpose: Selects the host interface on which Compose publishes container port 8000.
# How it works: This is a Compose-only interpolation variable, not an application
# setting. The application itself always listens on 0.0.0.0:8000 in the container.
# Default: 127.0.0.1 (loopback only)
# Valid values: a local bind address such as 127.0.0.1, 0.0.0.0, or ::1.
REMINDI_WEBUI_HOST=127.0.0.1

# REMINDI_WEBUI_PORT
# Purpose: Selects the host TCP port published by Compose.
# How it works: This is a Compose-only interpolation variable mapping the chosen
# host port to container port 8000.
# Default: 8000
# Valid values: an available TCP port from 1 through 65535.
REMINDI_WEBUI_PORT=8000
